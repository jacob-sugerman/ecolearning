# Asset files (large binary files)
# Users should obtain these separately using the recovery scripts
assets/**/*.glb
assets/**/*.gltf
assets/**/*.jpg
assets/**/*.jpeg
assets/**/*.png
assets/**/*.mp4
assets/**/*.webm
assets/**/*.mp3
assets/**/*.m4a
assets/**/*.wav

# Track asset files in-repo (except the large stream video)
!assets/models/*.glb
!assets/models/*.gltf
!assets/images/*.jpg
!assets/images/*.jpeg
!assets/images/*.png
!assets/videos/*.mp4
!assets/videos/*.webm
!assets/audio/*.mp3
!assets/audio/*.m4a
!assets/audio/*.wav

# Keep the large stream video out of the repo
assets/videos/Hoh_Forest_Stream.mp4

# Keep the directory structure and README
!assets/README.md
!assets/**/README.md
!assets/**/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/

# Recovery results
recovery_results.json

# Backups
*.backup
*.bak

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Editor files
.vscode/
.idea/
*.sublime-*
