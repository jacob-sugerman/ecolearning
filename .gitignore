# Asset files - committed to repo for GitHub Pages
# The patterns below first exclude all asset types, then re-include the tracked ones
assets/**/*.glb
assets/**/*.gltf
assets/**/*.jpg
assets/**/*.jpeg
assets/**/*.png
assets/**/*.mp4
assets/**/*.webm
assets/**/*.mp3
assets/**/*.m4a
assets/**/*.wav

# Track asset files in-repo
!assets/models/*.glb
!assets/models/*.gltf
!assets/images/*.jpg
!assets/images/*.jpeg
!assets/images/*.png
!assets/videos/*.mp4
!assets/videos/*.webm
!assets/audio/*.mp3
!assets/audio/*.m4a
!assets/audio/*.wav


# Keep the directory structure and README
!assets/README.md
!assets/**/README.md
!assets/**/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/

# Recovery results
recovery_results.json

# Backups
*.backup
*.bak

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Editor files
.vscode/
.idea/
*.sublime-*
